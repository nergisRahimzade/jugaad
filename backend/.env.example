# Redis — vector search + semantic cache + session memory + realtime queues
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_USERNAME=default
REDIS_INDEX_PREFIX=jugaad
REDIS_VECTOR_DIM=384              # all-MiniLM-L6-v2 dimensions
REDIS_SEMANTIC_CACHE_THRESHOLD=0.92

REDIS_LANGCACHE_API_KEY=
REDIS_LANGCACHE_ID=
REDIS_LANGCACHE_URL=
REDIS_LANGCACHE_EMBED_MODEL=

REDIS_AGENT_MEM_API_KEY=
REDIS_AGENT_MEM_URL=
REDIS_AGENT_MEM_STORE_ID=

# Browserbase — live Berkeley web crawl
# Dashboard: browserbase.com → Settings → API Keys
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_REGION=us-west-2

# Band — shared agent room for cross-domain context
BAND_API_KEY=
BAND_ROOM_ID=

# Deterministic seeds (keep stable for Agentverse addresses)
