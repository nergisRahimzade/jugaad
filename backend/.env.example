# Claude / Anthropic (Person 1 — orchestrator + agents)
ANTHROPIC_API_KEY=
ARIZE_SPACE_KEY=
ARIZE_API_KEY=

# Deepgram — voice STT/TTS (Person 2)
DEEPGRAM_API_KEY=

# Resend — deadline reminder emails (optional)
